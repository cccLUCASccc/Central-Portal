---
import BasicLayout from '../layouts/basic.astro';
import LivraisonManager from '../components/SveltesComponents/molecules/LivraisonManager.svelte';
---

<BasicLayout>
    <div class="max-w-6xl mx-auto">
        <div class="mb-8">
            <h1 class="text-3xl font-extrabold tracking-tight">Gestion des Livraisons</h1>
            <p class="text-base-content/60 mt-1">Configurez les tarifs de livraison par taille (S, M, L/XL) pour vos transporteurs.</p>
        </div>

        <div class="animate-in fade-in slide-in-from-bottom-4 duration-700">
            <LivraisonManager client:load />
        </div>
    </div>
</BasicLayout>
