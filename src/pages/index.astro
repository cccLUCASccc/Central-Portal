---
import TableSwitcher from '../components/SveltesComponents/molecules/TableSwitcher.svelte';
import BasicLayout from '../layouts/basic.astro';
import { Show } from '@clerk/astro/components';

const auth = Astro.locals.auth()
const token  = await auth.getToken()
const userId = auth.userId

let vehicules
let projets
let antiquites

if (userId){
    try{
        const API_URL = import.meta.env.API_URL;
        const finalUrl = `${API_URL}/api/projects`;

        console.log("🚀 URL appelée par Astro :", finalUrl);

        const response_projets = await fetch(finalUrl, {
            headers : {
                'Authorization' : `Bearer ${token}`
            }
        });

        if (!response_projets.ok) {
            throw new Error(`Aïe ! Erreur API : ${response_projets.status}`);
        }
        projets = await response_projets.json();

        const vehicules_url = `${API_URL}/api/vehicules`

        const response_vehicules = await fetch(vehicules_url, {
            headers : {
                'Authorization' : `Bearer ${token}`
            }
        });
        if (!response_vehicules.ok) {
            throw new Error(`Aïe ! Erreur API : ${response_vehicules.status}`);
        }

        vehicules = await response_vehicules.json();


        const antiquites_url = `${API_URL}/api/antiquites`
        const response_antiquites = await fetch(antiquites_url, {
            headers : {
                'Authorization' : `Bearer ${token}`
            }
        });
        if (!response_antiquites.ok) {
            throw new Error(`Aïe ! Erreur API : ${response_antiquites.status}`);
        }

        antiquites = await response_antiquites.json();
    }
    catch(error : any){
        console.error(error.message)
    }
}
---

<BasicLayout>
    <Show when="signed-in">
        <TableSwitcher client:load vehicules={vehicules} antiquites={antiquites} />
    </Show>
</BasicLayout>