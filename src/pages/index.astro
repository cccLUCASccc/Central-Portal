---
import TableAntiquites from '../components/SveltesComponents/molecules/TableAntiquites.svelte';
import BasicLayout from '../layouts/basic.astro';
import { Show } from '@clerk/astro/components';

const auth = Astro.locals.auth()
const token  = await auth.getToken()
const userId = auth.userId
const page = Astro.url.searchParams.get('page') || '1'
const category = Astro.url.searchParams.get('category') || ''
const status = Astro.url.searchParams.get('status') || ''
const priceMax = Astro.url.searchParams.get('priceMax') || ''
const nouveaute = Astro.url.searchParams.get('nouveaute') || ''

console.log("🛠️ [Index] Debug Auth - UserId:", userId);
console.log("🛠️ [Index] Debug Auth - Token present:", !!token);

if (userId && !token) {
    console.warn("⚠️ [Index] L'utilisateur est connecté mais aucun token n'a pu être récupéré. Vérifiez CLERK_SECRET_KEY.");
}

let antiquites = []
let antiquitesPagination = null

if (userId && token){
    try{
        const API_URL = import.meta.env.API_URL;
        if (!API_URL) {
            throw new Error("API_URL is not defined in environment variables");
        }
        
        console.log("🚀 [Index] Appels API vers:", API_URL);

        const fetchOptions = {
            headers : {
                'Authorization' : `Bearer ${token}`,
                'Content-Type': 'application/json'
            }
        };

        const queryParams = new URLSearchParams({ page });
        if (category) queryParams.set('category', category);
        if (status) queryParams.set('status', status);
        if (priceMax) queryParams.set('priceMax', priceMax);
        if (nouveaute) queryParams.set('nouveaute', nouveaute);

        // Fetch Antiquités
        const response_antiquites = await fetch(`${API_URL}/api/antiquites?${queryParams.toString()}`, fetchOptions);
        if (!response_antiquites.ok) {
            console.error(`❌ Erreur Antiquités: ${response_antiquites.status}`);
        } else {
            const result = await response_antiquites.json();
            antiquites = result.data || result;
            antiquitesPagination = result.pagination;
        }
    }
    catch(error : any){
        console.error("🔥 Erreur lors du fetch SSR:", error.message)
    }
}
---

<BasicLayout>
    <Show when="signed-in">
        <TableAntiquites 
            client:load 
            apiUrl={import.meta.env.API_URL}
            antiquites={antiquites} 
            pagination={antiquitesPagination}
        />
    </Show>
</BasicLayout>