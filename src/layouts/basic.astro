---
import "../styles/global.css";
import { Show, UserButton } from '@clerk/astro/components';
import ThemeController from "../components/SveltesComponents/atoms/ThemeController.svelte";

const auth = Astro.locals.auth()
const token  = await auth.getToken()
const userId = auth.userId

console.log("🛠️ [Layout] Debug Auth - UserId:", userId);
console.log("🛠️ [Layout] Debug Auth - Token present:", !!token);

if (userId && !token) {
    console.warn("⚠️ [Layout] L'utilisateur est connecté mais aucun token n'a pu être récupéré.");
}
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Central Portal</title>
    <script is:inline>
      // Initialisation du thème pour éviter le flash blanc/noir
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dracula';
        }
        return 'corporate';
      })();
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  
  <body class="min-h-screen bg-base-100 flex flex-col font-sans transition-colors duration-300">
    
    <div class="drawer">
      <input id="my-drawer" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content flex flex-col">
        
        <Show when="signed-in">
          <!-- Navbar -->
          <header class="navbar bg-base-100/80 backdrop-blur-md sticky top-0 z-50 border-b border-base-200 px-4">
            <div class="flex-none lg:hidden">
              <label for="my-drawer" aria-label="open sidebar" class="btn btn-square btn-ghost">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
              </label>
            </div>
            
            <div class="flex-1 px-2 mx-2 font-bold text-xl tracking-tight">
              <a href="/" class="hover:text-primary transition-colors">Central Portal</a>
            </div>

            <div class="flex-none hidden lg:block">
              <ul class="menu menu-horizontal px-1 gap-2">
                <li><a href="/" class="rounded-lg">Inventaire</a></li>
                <li><a href="/Livraison" class="rounded-lg">Livraisons</a></li>
                <li><a href="/blog" class="rounded-lg">Blog</a></li>
              </ul>
            </div>

            <div class="flex-none gap-4 ml-2">
              <ThemeController client:load />
              <div class="divider divider-horizontal mx-0 h-8 self-center"></div>
              <UserButton />
            </div>
          </header>
        </Show>

        <!-- Main Content -->
        <main class="flex-grow flex flex-col relative">
          <Show when="signed-in">
            <div class="p-4 md:p-8 animate-in fade-in slide-in-from-bottom-4 duration-700">
              <slot />
            </div>
          </Show>
        </main>
        
        <footer class="footer footer-center p-4 bg-base-200 text-base-content border-t border-base-300">
          <aside>
            <p>Copyright © 2026 - Tous droits réservés par Central Portal</p>
          </aside>
        </footer>
      </div> 

      <!-- Drawer Side (Mobile Navigation) -->
      <div class="drawer-side z-[100]">
        <label for="my-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
        <ul class="menu p-4 w-80 min-h-full bg-base-100 text-base-content">
          <li class="mb-4">
            <div class="text-xl font-bold px-2 py-4">Menu</div>
          </li>
          <li><a href="/" class="flex items-center gap-3">🏠 Accueil</a></li>
          <li><a href="/Livraison" class="flex items-center gap-3">🚚 Livraisons</a></li>
          <li><a href="/blog" class="flex items-center gap-3">📰 Blog</a></li>
        </ul>
      </div>
    </div>
  </body>
</html>