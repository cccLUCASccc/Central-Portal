---
import "../styles/global.css";
import { Show, UserButton, SignInButton } from '@clerk/astro/components';
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Central Portal</title>
  </head>
  
  <body class="min-h-screen bg-base-100 flex flex-col">
    
    <header class="w-full flex items-center justify-between p-4 bg-base-200 shadow-sm z-50">
      <div class="font-bold text-xl">
        Central Portal
      </div>
      
      <div class="flex items-center gap-4">
        <Show when="signed-in">
          <UserButton />
        </Show>
      </div>
    </header>

    <main class="flex-grow p-4 md:p-8 flex flex-col">
      
      <Show when="signed-out">
        <div class="flex-grow flex items-center justify-center">
          <div class="card w-96 bg-base-200 shadow-xl border border-base-300">
            <div class="card-body items-center text-center gap-4">
              <h2 class="card-title text-2xl">Accès Restreint 🔒</h2>
              <p class="text-sm opacity-70">Veuillez vous identifier pour gérer le portail.</p>
              
              <SignInButton mode="modal">
                <button class="btn btn-primary w-full mt-2">
                  Se connecter
                </button>
              </SignInButton>
            </div>
          </div>
        </div>
      </Show>

      <Show when="signed-in">
        <slot />
      </Show>
      
    </main>
  </body>
</html>